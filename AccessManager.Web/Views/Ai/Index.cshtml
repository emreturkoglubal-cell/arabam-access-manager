@{
    ViewData["Title"] = "arabam AI — Proje Sohbeti";
    var initialConversationId = ViewData["ConversationId"] as int?;
}
<div class="ai-chat-page-wrap">
<div class="am-card d-flex flex-column ai-chat-card">
    <div class="am-card-body d-flex flex-grow-1 p-0 ai-chat-body">
        <aside id="conversationSidebar" class="am-ai-sidebar border-end bg-light d-flex flex-column ai-chat-sidebar">
            <div class="p-2 border-bottom bg-white flex-shrink-0">
                <a href="/Ai/Index" class="btn btn-sm btn-am-outline w-100">+ Yeni sohbet</a>
            </div>
            <div id="conversationListWrap" class="flex-grow-1 overflow-y-auto ai-chat-list-wrap">
                <div id="conversationList" class="list-group list-group-flush">
                    <div class="text-muted small text-center py-3">Yükleniyor...</div>
                </div>
                <div id="conversationListMore" class="p-2 text-center border-top bg-white" style="display: none;">
                    <button type="button" id="loadMoreConversations" class="btn btn-sm btn-am-outline">Daha fazla yükle</button>
                </div>
            </div>
        </aside>
        <div class="d-flex flex-column flex-grow-1 ai-chat-main" style="min-width: 0;">
            <div id="chatMessages" class="flex-grow-1 overflow-auto p-3" style="min-height: 0;">
                <div id="welcomePlaceholder" class="text-center py-5 px-3">
                    <p id="welcomeTypewriter" class="text-muted mb-0" style="min-height: 2.5em; font-size: 1.05rem; line-height: 1.6;"></p>
                </div>
            </div>
            <div class="border-top p-3 bg-light flex-shrink-0">
                <div class="d-flex gap-2 align-items-end">
                    <textarea id="chatInput" class="form-control ai-chat-input" rows="2" placeholder="Mesajınızı yazın..." autocomplete="off"></textarea>
                    <button type="button" id="chatSend" class="btn btn-am-primary flex-shrink-0">Gönder</button>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<style>
    .ai-chat-page-wrap { display: flex; flex-direction: column; flex: 1 1 0; min-height: 0; }
    .ai-chat-card { flex: 1 1 0; min-height: 320px; }
    .ai-chat-body { min-height: 0; height: 100%; }
    .ai-chat-sidebar { width: 260px; min-width: 260px; min-height: 0; }
    .ai-chat-list-wrap { min-height: 0; }
    .ai-chat-main { min-height: 0; }
    .ai-chat-input { resize: vertical; min-height: 2.5rem; max-height: 12rem; }
    .typing-indicator { display: inline-flex; align-items: center; gap: 4px; padding: 12px 16px; }
    .typing-indicator span { width: 6px; height: 6px; border-radius: 50%; background: var(--am-accent, #e40030); animation: typing-blink 1.2s ease-in-out infinite both; }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    .typing-indicator span:nth-child(4) { animation-delay: 0.6s; }
    @@keyframes typing-blink { 0%, 80%, 100% { opacity: 0.3; transform: scale(0.9); } 40% { opacity: 1; transform: scale(1); } }
    /* AI cevabında kod blokları – beyaz arka plan, tema rengi vurgu (sol çizgi) */
    .am-ai-code-block {
        margin: 0.75rem 0;
        padding: 1rem 1.25rem;
        background: var(--am-card-bg, #ffffff);
        color: var(--am-text, #111827);
        border-radius: 8px;
        border: 1px solid var(--am-border, #e5e7eb);
        border-left: 4px solid var(--am-accent, #e40030);
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 0.9rem;
        line-height: 1.5;
        overflow-x: auto;
        white-space: pre;
        text-align: left;
    }
    .am-ai-code-block code { background: none; color: inherit; padding: 0; font-size: inherit; }
    /* Diff blokları: silinen satır soft kırmızı, eklenen satır soft yeşil */
    .am-ai-diff-block {
        margin: 0.75rem 0;
        padding: 0;
        background: var(--am-card-bg, #ffffff);
        color: var(--am-text, #111827);
        border-radius: 8px;
        border: 1px solid var(--am-border, #e5e7eb);
        border-left: 4px solid var(--am-accent, #e40030);
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 0.9rem;
        line-height: 1.5;
        overflow-x: auto;
        text-align: left;
    }
    .am-ai-diff-line {
        display: block;
        white-space: pre;
        padding: 0.15rem 1rem;
        min-height: 1.4em;
    }
    .am-ai-diff-del {
        background: #fef2f2;
        color: #991b1b;
    }
    .am-ai-diff-add {
        background: #dcfce7;
        color: #166534;
    }
    .am-ai-inline-code {
        background: var(--am-accent-light, #fef2f2);
        color: var(--am-accent, #e40030);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 0.9em;
    }
    /* AI cevabında markdown başlıkları */
    .am-ai-h1 { font-size: 1.35rem; font-weight: 700; margin: 1rem 0 0.5rem; color: var(--am-text, #111827); }
    .am-ai-h2 { font-size: 1.2rem; font-weight: 700; margin: 0.9rem 0 0.4rem; color: var(--am-text, #111827); }
    .am-ai-h3 { font-size: 1.05rem; font-weight: 600; margin: 0.75rem 0 0.35rem; color: var(--am-accent, #e40030); }
</style>

@section Scripts {
<script>
(function () {
    var messagesEl = document.getElementById('chatMessages');
    var inputEl = document.getElementById('chatInput');
    var sendBtn = document.getElementById('chatSend');
    var listEl = document.getElementById('conversationList');
    var listMoreEl = document.getElementById('conversationListMore');
    var loadMoreBtn = document.getElementById('loadMoreConversations');
    var currentConversationId = @(initialConversationId.HasValue ? initialConversationId.Value : "null");
    var conversationsSkip = 0;
    var conversationPageSize = 20;
    var conversationsTotal = 0;

    function scrollToBottom() {
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function escapeHtml(s) {
        if (!s) return '';
        var div = document.createElement('div');
        div.textContent = s;
        return div.innerHTML;
    }
    // Diff bloğu: satır başı - (silinen) -> soft kırmızı, + (eklenen) -> soft yeşil
    function formatDiffBlock(code) {
        var lines = code.split(/\r?\n/);
        var html = ['<div class="am-ai-code-block am-ai-diff-block">'];
        for (var i = 0; i < lines.length; i++) {
            var line = lines[i];
            var cls = 'am-ai-diff-line';
            if (line.length >= 1) {
                if (line.charAt(0) === '-' && line.substring(0, 3) !== '---') cls += ' am-ai-diff-del';
                else if (line.charAt(0) === '+' && line.substring(0, 3) !== '+++') cls += ' am-ai-diff-add';
            }
            html.push('<div class="' + cls + '">' + escapeHtml(line) + '</div>');
        }
        html.push('</div>');
        return html.join('');
    }
    // Markdown: kod blokları ```lang\n...\n``` -> <pre><code>; diff ise satır bazlı renk
    function formatAssistantMessage(text) {
        var raw = text || '';
        var out = [];
        var codeBlockRe = /```(\w*)\r?\n([\s\S]*?)```/g;
        var lastEnd = 0;
        var m;
        while ((m = codeBlockRe.exec(raw)) !== null) {
            var before = raw.slice(lastEnd, m.index);
            out.push(formatInlineMarkdown(before));
            var lang = (m[1] || 'text').toLowerCase();
            if (lang === 'cs') lang = 'csharp';
            var code = m[2].replace(/\r\n/g, '\n').trimEnd();
            if (lang === 'diff') {
                out.push(formatDiffBlock(code));
            } else {
                out.push('<pre class="am-ai-code-block"><code class="language-' + escapeHtml(lang) + '">' + escapeHtml(code) + '</code></pre>');
            }
            lastEnd = codeBlockRe.lastIndex;
        }
        out.push(formatInlineMarkdown(raw.slice(lastEnd)));
        return out.join('');
    }
    function formatInlineMarkdown(s) {
        var escaped = escapeHtml(s);
        // Markdown başlıklar (satır başı #, ##, ###)
        escaped = escaped.replace(/^### (.+)$/gm, function(_, t) { return '<h3 class="am-ai-h3">' + t + '</h3>'; });
        escaped = escaped.replace(/^## (.+)$/gm, function(_, t) { return '<h2 class="am-ai-h2">' + t + '</h2>'; });
        escaped = escaped.replace(/^# (.+)$/gm, function(_, t) { return '<h1 class="am-ai-h1">' + t + '</h1>'; });
        escaped = escaped.replace(/\n/g, '<br/>');
        escaped = escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
        escaped = escaped.replace(/`([^`]+)`/g, '<code class="am-ai-inline-code">$1</code>');
        return escaped;
    }

    function addMessage(role, text) {
        var wrap = document.createElement('div');
        wrap.className = 'mb-3 ' + (role === 'user' ? 'text-end' : 'text-start');
        var bubble = document.createElement('div');
        bubble.className = role === 'user'
            ? 'd-inline-block text-start p-3 rounded-3 bg-am-primary text-dark shadow-sm'
            : 'd-inline-block text-start p-3 rounded-3 bg-light border shadow-sm';
        bubble.style.maxWidth = '85%';
        if (role === 'assistant')
            bubble.innerHTML = formatAssistantMessage(text);
        else
            bubble.textContent = text;
        wrap.appendChild(bubble);
        messagesEl.appendChild(wrap);
        scrollToBottom();
    }

    function addTypingIndicator() {
        var wrap = document.createElement('div');
        wrap.className = 'mb-3 text-start';
        wrap.id = 'typingIndicatorWrap';
        var bubble = document.createElement('div');
        bubble.className = 'd-inline-block text-start p-3 rounded-3 bg-light border shadow-sm';
        bubble.innerHTML = '<div class="typing-indicator"><span></span><span></span><span></span><span></span></div>';
        wrap.appendChild(bubble);
        messagesEl.appendChild(wrap);
        scrollToBottom();
    }
    function removeTypingIndicator() {
        var el = document.getElementById('typingIndicatorWrap');
        if (el) el.remove();
    }

    var welcomePlaceholderEl = document.getElementById('welcomePlaceholder');
    var welcomeTypewriterEl = document.getElementById('welcomeTypewriter');
    var welcomeTexts = [
        'Proje kodu hakkında soru sorun. Örn: "Personellerde onay akışı nasıl çalışıyor?"',
        'Kod değişikliği isteyebilirsiniz; AI dosyaları düzenleyip patch üretebilir.',
        'Belirli bir dosyayı veya akışı anlatmasını isteyin: "Login sayfası nerede?"',
        'Refactoring veya yeni özellik önerisi isteyin; projede canlıda gerçekten kod değiştirebilirsiniz.'
    ];
    var typewriterTimeoutId = null;
    var typewriterTextIndex = 0;
    var typewriterCharIndex = 0;

    function stopTypewriter() {
        if (typewriterTimeoutId) {
            clearTimeout(typewriterTimeoutId);
            typewriterTimeoutId = null;
        }
    }

    function runTypewriterStep() {
        if (!welcomePlaceholderEl || welcomePlaceholderEl.style.display === 'none') return;
        var text = welcomeTexts[typewriterTextIndex];
        if (typewriterCharIndex <= text.length) {
            welcomeTypewriterEl.textContent = text.slice(0, typewriterCharIndex);
            typewriterCharIndex++;
            typewriterTimeoutId = setTimeout(runTypewriterStep, typewriterCharIndex === 1 ? 200 : (Math.random() * 20 + 28));
            return;
        }
        typewriterTimeoutId = setTimeout(function () {
            typewriterTextIndex = (typewriterTextIndex + 1) % welcomeTexts.length;
            typewriterCharIndex = 0;
            if (welcomePlaceholderEl && welcomePlaceholderEl.style.display !== 'none')
                typewriterTimeoutId = setTimeout(runTypewriterStep, 300);
        }, 1100);
    }

    function startTypewriter() {
        stopTypewriter();
        if (!welcomePlaceholderEl || !welcomeTypewriterEl) return;
        typewriterTextIndex = 0;
        typewriterCharIndex = 0;
        welcomeTypewriterEl.textContent = '';
        typewriterTimeoutId = setTimeout(runTypewriterStep, 200);
    }

    function setPlaceholder(visible) {
        if (!welcomePlaceholderEl) return;
        welcomePlaceholderEl.style.display = visible ? '' : 'none';
        if (visible) startTypewriter();
        else stopTypewriter();
    }

    function appendConversationItems(items) {
        if (!items || items.length === 0) return;
        items.forEach(function (c) {
            var a = document.createElement('a');
            a.href = '/Ai/Index?conversationId=' + c.id;
            a.className = 'list-group-item list-group-item-action' + (currentConversationId === c.id ? ' active' : '');
            a.textContent = (c.title || '(Sohbet)').substring(0, 50) + (c.title && c.title.length > 50 ? '…' : '');
            listEl.appendChild(a);
        });
    }

    function loadConversations(append) {
        var skip = append ? conversationsSkip : 0;
        if (!append) listEl.innerHTML = '<div class="text-muted small text-center py-3">Yükleniyor...</div>';
        fetch('/Ai/GetConversations?skip=' + skip + '&take=' + conversationPageSize)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                var items = data.items || [];
                conversationsTotal = data.total || 0;
                if (!append) listEl.innerHTML = '';
                if (!append && items.length === 0) {
                    listEl.innerHTML = '<div class="text-muted small text-center py-3">Henüz sohbet yok</div>';
                    listMoreEl.style.display = 'none';
                    return;
                }
                appendConversationItems(items);
                conversationsSkip = skip + items.length;
                listMoreEl.style.display = (data.hasMore ? '' : 'none');
            })
            .catch(function () {
                if (!append) listEl.innerHTML = '<div class="text-danger small text-center py-3">Liste yüklenemedi</div>';
                listMoreEl.style.display = 'none';
            });
    }
    loadMoreBtn.addEventListener('click', function () { loadConversations(true); });

    function loadMessages(conversationId) {
        if (!conversationId) {
            setPlaceholder(true);
            messagesEl.querySelectorAll('.mb-3').forEach(function (el) { el.remove(); });
            return;
        }
        setPlaceholder(false);
        messagesEl.querySelectorAll('.mb-3').forEach(function (el) { el.remove(); });
        fetch('/Ai/GetMessages?conversationId=' + conversationId)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                var items = data.messages || [];
                if (items.length === 0) {
                    setPlaceholder(true);
                    return;
                }
                setPlaceholder(false);
                items.forEach(function (m) {
                    addMessage(m.role, m.content || '');
                });
            })
            .catch(function () {
                addMessage('assistant', 'Mesajlar yüklenemedi.');
            });
    }

    loadConversations(false);
    if (currentConversationId) {
        loadMessages(currentConversationId);
        setPlaceholder(false);
    } else {
        startTypewriter();
    }

    sendBtn.addEventListener('click', function () {
        var msg = (inputEl.value || '').trim();
        if (!msg) return;
        setPlaceholder(false);
        addMessage('user', msg);
        inputEl.value = '';
        sendBtn.disabled = true;
        addTypingIndicator();

        var body = { message: msg };
        if (currentConversationId) body.conversationId = currentConversationId;

        fetch('/Ai/Chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        })
        .then(function (r) {
            return r.text().then(function (text) {
                var data = null;
                if (text && text.trim().length > 0) {
                    try { data = JSON.parse(text); } catch (e) { /* response JSON değil */ }
                }
                if (!r.ok) {
                    var errMsg = (data && data.reply) ? data.reply : ('HTTP ' + r.status + (text ? ': ' + text.substring(0, 200) : ''));
                    throw new Error(errMsg);
                }
                if (!data) throw new Error('Sunucu boş veya geçersiz yanıt döndü. Zaman aşımı veya ağ hatası olabilir.');
                return data;
            });
        })
        .then(function (data) {
            removeTypingIndicator();
            if (data.conversationId && !currentConversationId) {
                currentConversationId = data.conversationId;
                var newUrl = '/Ai/Index?conversationId=' + data.conversationId;
                if (window.history && window.history.replaceState)
                    window.history.replaceState(null, '', newUrl);
                loadConversations(false);
            }
            addMessage('assistant', data.reply || '(cevap yok)');
        })
        .catch(function (err) {
            removeTypingIndicator();
            addMessage('assistant', 'İstek hatası: ' + (err.message || String(err)));
        })
        .finally(function () {
            sendBtn.disabled = false;
            inputEl.focus();
        });
    });

    inputEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendBtn.click();
        }
    });
    inputEl.focus();
})();
</script>
}
