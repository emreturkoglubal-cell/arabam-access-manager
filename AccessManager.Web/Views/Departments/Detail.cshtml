@using AccessManager.Domain.Entities
@using AccessManager.Domain.Enums
@{
    ViewData["Title"] = "Departman Detay";
    var department = ViewBag.Department as Department;
    var personnelCount = ViewBag.PersonnelCount as int? ?? 0;
    var personnelList = ViewBag.PersonnelList as IReadOnlyList<Personnel> ?? new List<Personnel>();
    var personnelTotalCount = ViewBag.PersonnelTotalCount as int? ?? 0;
    var personnelPageNumber = ViewBag.PersonnelPageNumber as int? ?? 1;
    var personnelTotalPages = ViewBag.PersonnelTotalPages as int? ?? 1;
    var personnelPageSize = ViewBag.PersonnelPageSize as int? ?? 10;
    var roleNames = ViewBag.RoleNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var departmentNames = ViewBag.DepartmentNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var managerNames = ViewBag.ManagerNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var departmentManagers = ViewBag.DepartmentManagers as IReadOnlyList<DepartmentManager> ?? new List<DepartmentManager>();
    var departmentManagerPersonnel = ViewBag.DepartmentManagerPersonnel as Dictionary<int, Personnel> ?? new Dictionary<int, Personnel>();
    var allPersonnelForGmy = ViewBag.AllPersonnelForGmy as IReadOnlyList<Personnel> ?? new List<Personnel>();
}
@if (department == null)
{
    <p class="text-muted">Departman bulunamadı.</p>
}
else
{
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Departments" asp-action="Index">Departmanlar</a></li>
        <li class="breadcrumb-item active">@department.Name</li>
    </ol>
</nav>

@if (TempData["DepartmentEditSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["DepartmentEditSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["DepartmentEditError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["DepartmentEditError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

<div class="am-card mb-3">
    <div class="am-card-header d-flex justify-content-between align-items-center">
        <span>Departman Bilgileri</span>
        <button type="button" class="btn btn-sm btn-am-outline" data-bs-toggle="modal" data-bs-target="#departmentEditModal" aria-label="Departman bilgilerini düzenle">Düzenle</button>
    </div>
    <div class="am-card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">@department.Id</dd>
            <dt class="col-sm-4">Kod</dt>
            <dd class="col-sm-8">@(department.Code ?? "—")</dd>
            <dt class="col-sm-4">Departman Adı</dt>
            <dd class="col-sm-8">@department.Name</dd>
            <dt class="col-sm-4">Açıklama</dt>
            <dd class="col-sm-8">@(department.Description ?? "—")</dd>
            <dt class="col-sm-4">Personel sayısı</dt>
            <dd class="col-sm-8">@personnelCount</dd>
        </dl>
    </div>
</div>

@if (departmentManagers.Any())
{
<div class="am-card mb-3">
    <div class="am-card-header">1. / 2. / 3. Yöneticiler</div>
    <div class="am-card-body p-0">
        <div class="am-table-wrap">
            <table class="am-table mb-0">
                <thead>
                    <tr>
                        <th class="am-table-th-normal">Seviye</th>
                        <th class="am-table-th-normal">Ad Soyad</th>
                        <th class="am-table-th-normal">Ünvan</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dm in departmentManagers.OrderBy(x => x.ManagerLevel).ThenBy(x => x.DisplayOrder))
                    {
                        var p = departmentManagerPersonnel.TryGetValue(dm.PersonnelId, out var per) ? per : null;
                        var levelLabel = dm.ManagerLevel == 1 ? "1. Yönetici" : dm.ManagerLevel == 2 ? "2. Yönetici" : "3. Yönetici";
                        <tr>
                            <td>@levelLabel</td>
                            <td>
                                @if (p != null)
                                {
                                    <a class="am-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@p.Id">@p.FirstName @p.LastName</a>
                                }
                                else
                                {
                                    @:—
                                }
                            </td>
                            <td>@(p?.Position ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
}

<div class="am-card mb-3">
    <div class="am-card-header">Bu departmandaki personeller (aktif)</div>
    <div class="am-card-body p-0">
        <div class="am-table-wrap">
            <table class="am-table am-table-rows-clickable">
                <thead>
                    <tr>
                        <th class="am-table-col-avatar"></th>
                        <th class="am-table-th-normal">ID</th>
                        <th class="am-table-th-normal">Ad Soyad</th>
                        <th class="am-table-th-normal">E-posta</th>
                        <th class="am-table-th-normal">Rol</th>
                        <th class="am-table-th-normal">Yönetici İsmi</th>
                        <th class="am-table-th-normal">Giriş</th>
                        <th class="am-table-th-normal">Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in personnelList)
                    {
                        var roleName = p.RoleId.HasValue && roleNames.TryGetValue(p.RoleId.Value, out var rn) ? rn : "—";
                        var managerName = p.ManagerId.HasValue && managerNames.TryGetValue(p.ManagerId.Value, out var mn) ? mn : "—";
                        var detailUrl = Url.Action("Detail", "Personnel", new { id = p.Id }) ?? "#";
                        <tr class="am-table-row-clickable" data-href="@detailUrl" role="button" tabindex="0">
                            <td class="am-table-cell-avatar">
                                @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="" class="am-avatar am-avatar-sm" />
                                }
                                else
                                {
                                    <span class="am-avatar am-avatar-sm am-avatar-default" aria-hidden="true"><i class="bi bi-person-circle"></i></span>
                                }
                            </td>
                            <td>@p.Id</td>
                            <td>@p.FirstName @p.LastName</td>
                            <td>@p.Email</td>
                            <td>@roleName</td>
                            <td>@managerName</td>
                            <td>@p.StartDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="am-badge @(p.Status == PersonnelStatus.Active ? "success" : p.Status == PersonnelStatus.Offboarded ? "secondary" : "warning")">@StatusLabels.PersonnelStatus(p.Status)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!personnelList.Any())
        {
            <p class="text-muted mb-0 p-3">Bu departmanda aktif personel yok.</p>
        }
        else if (personnelTotalPages > 1)
        {
            <div class="p-3">
                @await Html.PartialAsync("_Pagination", new AccessManager.UI.ViewModels.PaginationViewModel
                {
                    Controller = "Departments",
                    Action = "Detail",
                    PageNumber = personnelPageNumber,
                    TotalPages = personnelTotalPages,
                    TotalCount = personnelTotalCount,
                    PageSize = personnelPageSize,
                    RouteValues = new Microsoft.AspNetCore.Routing.RouteValueDictionary { ["id"] = department!.Id }
                })
            </div>
        }
    </div>
</div>

<div class="modal fade" id="departmentEditModal" tabindex="-1" aria-labelledby="departmentEditModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="departmentEditModalLabel">Departman bilgilerini düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <form method="post" asp-controller="Departments" asp-action="UpdateDepartment" asp-route-id="@department.Id">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editName" class="form-label">Departman Adı</label>
                        <input type="text" name="Name" id="editName" class="form-control" value="@department.Name" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label for="editCode" class="form-label">Kod</label>
                        <input type="text" name="Code" id="editCode" class="form-control" value="@department.Code" maxlength="50" />
                    </div>
                    <div class="mb-3">
                        <label for="editDescription" class="form-label">Açıklama</label>
                        <textarea name="Description" id="editDescription" class="form-control" rows="3" maxlength="2000">@department.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label for="editTopManagerPersonnelId" class="form-label">Departman Yöneticisi (GMY)</label>
                        <select name="TopManagerPersonnelId" id="editTopManagerPersonnelId" class="form-select">
                            <option value="">— Seçiniz —</option>
                            @foreach (var p in allPersonnelForGmy)
                            {
                                <option value="@p.Id" selected="@(department.TopManagerPersonnelId == p.Id)">@p.FirstName @p.LastName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-am-ghost" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-am-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<a asp-controller="Departments" asp-action="Index" class="btn btn-am-ghost">Listeye dön</a>
}
