@using AccessManager.Domain.Entities
@{
    ViewData["Title"] = "Departmanlar";
    var departments = ViewBag.Departments as IReadOnlyList<Department> ?? new List<Department>();
    var countByDept = ViewBag.PersonnelCountByDepartment as Dictionary<int, int> ?? new Dictionary<int, int>();
    var topManagerNames = ViewBag.TopManagerNames as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="am-toolbar mb-3">
    <div class="am-toolbar-end">
        <a asp-controller="Departments" asp-action="Create" class="btn btn-am-primary">Yeni Departman Ekle</a>
    </div>
</div>

<div class="am-card">
    <div class="am-card-body p-0">
        <div class="am-table-wrap am-table-rows-clickable">
            <table class="am-table">
                <thead>
                    <tr>
                        <th class="am-table-th-normal">Kod</th>
                        <th class="am-table-th-normal">Departman Adı</th>
                        <th class="am-table-th-normal">Departman Yöneticisi (GMY)</th>
                        <th class="am-table-th-normal">Personel sayısı</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in departments)
                    {
                        var gmyName = d.TopManagerPersonnelId.HasValue && topManagerNames.TryGetValue(d.TopManagerPersonnelId.Value, out var gmy) ? gmy : "—";
                        <tr role="button" tabindex="0" class="am-table-row-clickable" data-href="@Url.Action("Detail", "Departments", new { id = d.Id })" onclick="window.location.href=this.dataset.href">
                            <td>@(d.Code ?? "—")</td>
                            <td>@d.Name</td>
                            <td>@gmyName</td>
                            <td>@(countByDept.TryGetValue(d.Id, out var c) ? c : 0)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
