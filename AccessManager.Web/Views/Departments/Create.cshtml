@model AccessManager.UI.ViewModels.DepartmentCreateInputModel
@using AccessManager.Domain.Entities
@{
    ViewData["Title"] = "Yeni Departman";
    var allDepts = ViewBag.AllDepartments as IReadOnlyList<Department> ?? new List<Department>();
    var gmyList = ViewBag.AllPersonnelForGmy as IReadOnlyList<Personnel> ?? new List<Personnel>();
}

<div class="am-card am-card--narrow">
    <div class="am-card-body">
        <form method="post" asp-controller="Departments" asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Departman adı <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Örn. Yazılım Geliştirme" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Code" class="form-label">Kod</label>
                <input asp-for="Code" class="form-control" placeholder="Örn. YAZ" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="2" placeholder="İsteğe bağlı"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="ParentId" class="form-label">Üst departman</label>
                <select asp-for="ParentId" class="form-select">
                    <option value="">— Yok (kök departman) —</option>
                    @foreach (var d in allDepts)
                    {
                        <option value="@d.Id">@d.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="TopManagerPersonnelId" class="form-label">Departman yöneticisi (GMY)</label>
                <select asp-for="TopManagerPersonnelId" class="form-select">
                    <option value="">— Seçiniz —</option>
                    @foreach (var p in gmyList)
                    {
                        <option value="@p.Id">@p.FirstName @p.LastName</option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-am-primary">Oluştur</button>
                <a asp-controller="Departments" asp-action="Index" class="btn btn-am-ghost">İptal</a>
            </div>
        </form>
    </div>
</div>
