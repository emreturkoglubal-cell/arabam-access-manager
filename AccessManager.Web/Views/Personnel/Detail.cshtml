@model AccessManager.UI.ViewModels.PersonnelDetailViewModel
@using AccessManager.Domain.Enums
@using AccessManager.Domain.Entities
@{
    ViewData["Title"] = "Personel Detay";
    var managersForEdit = ViewBag.ManagersForEdit as IReadOnlyList<Personnel> ?? new List<Personnel>();
    var departmentsForEdit = ViewBag.Departments as IReadOnlyList<Department> ?? new List<Department>();
    var rolesForEdit = ViewBag.Roles as IReadOnlyList<Role> ?? new List<Role>();
    var isManager = ViewBag.IsManager as bool? ?? false;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Personnel" asp-action="Index">Personel</a></li>
        <li class="breadcrumb-item active">@(Model.Personnel?.FirstName) @(Model.Personnel?.LastName)</li>
    </ol>
</nav>

@if (Model.Personnel == null)
{
    <p class="text-muted">Personel bulunamadı.</p>
}
else
{
@if (TempData["RevokeError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["RevokeError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["GrantError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["GrantError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["ManagerUpdateSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["ManagerUpdateSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["ManagerUpdateError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ManagerUpdateError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["PersonnelEditSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["PersonnelEditSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["PersonnelEditError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["PersonnelEditError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

<div class="am-personnel-detail-header mb-4">
    @if (!string.IsNullOrWhiteSpace(Model.Personnel.ImageUrl))
    {
        <img src="@Model.Personnel.ImageUrl" alt="" class="am-avatar am-avatar-lg" />
    }
    else
    {
        <span class="am-avatar am-avatar-lg am-avatar-default" aria-hidden="true"><i class="bi bi-person-circle"></i></span>
    }
</div>

<div class="row">
    <div class="col-md-6">
        <div class="am-card mb-3">
            <div class="am-card-header d-flex justify-content-between align-items-center">
                <span>Kişisel Bilgiler</span>
                <button type="button" class="btn btn-sm btn-am-outline" data-bs-toggle="modal" data-bs-target="#personnelEditModal" aria-label="Kişisel bilgileri düzenle">Düzenle</button>
            </div>
            <div class="am-card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">E-posta</dt>
                    <dd class="col-sm-8">@Model.Personnel.Email</dd>
                    <dt class="col-sm-4">Departman</dt>
                    <dd class="col-sm-8">@Model.DepartmentName</dd>
                    <dt class="col-sm-4">Pozisyon</dt>
                    <dd class="col-sm-8">@(Model.Personnel.Position ?? "-")</dd>
                    <dt class="col-sm-4">Rol</dt>
                    <dd class="col-sm-8">@(Model.RoleName ?? "-")</dd>
                    <dt class="col-sm-4">Yönetici İsmi</dt>
                    <dd class="col-sm-8">
                        @if (Model.Personnel.ManagerId.HasValue && !string.IsNullOrEmpty(Model.ManagerName))
                        {
                            <a class="am-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@Model.Personnel.ManagerId.Value">@Model.ManagerName</a>
                        }
                        else
                        {
                            @(Model.ManagerName ?? "-")
                        }
                    </dd>
                    <dt class="col-sm-4">İşe giriş</dt>
                    <dd class="col-sm-8">@Model.Personnel.StartDate.ToString("dd.MM.yyyy")</dd>
                    <dt class="col-sm-4">İşten çıkış</dt>
                    <dd class="col-sm-8">@(Model.Personnel.EndDate?.ToString("dd.MM.yyyy") ?? "-")</dd>
                    <dt class="col-sm-4">Durum</dt>
                    <dd class="col-sm-8">
                        @{
                            var statusBadgeClass = Model.Personnel.Status == PersonnelStatus.Active ? "success" : "secondary";
                        }
                        <span class="am-badge @statusBadgeClass">@StatusLabels.PersonnelStatus(Model.Personnel.Status)</span>
                    </dd>
                </dl>
            </div>
        </div>
        @if (Model.SubordinatesTotalCount > 0)
        {
        <div class="am-card mb-3">
            <div class="am-card-header">Bağlı olan personeller</div>
            <div class="am-card-body">
                <div class="am-table-wrap">
                    <table class="am-table mb-0">
                        <thead>
                            <tr>
                                <th class="am-table-th-normal">Ad Soyad</th>
                                <th class="am-table-th-normal">Pozisyon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in Model.Subordinates)
                            {
                                <tr>
                                    <td>
                                        <a class="am-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@sub.Id">@sub.FirstName @sub.LastName</a>
                                    </td>
                                    <td>@(sub.Position ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.SubordinatesTotalCount > Model.SubordinatesPageSize)
                {
                    var totalPages = (Model.SubordinatesTotalCount + Model.SubordinatesPageSize - 1) / Model.SubordinatesPageSize;
                    <nav aria-label="Bağlı personeller sayfaları" class="mt-2">
                        <ul class="pagination pagination-sm mb-0">
                            @if (Model.SubordinatesPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@Model.Personnel.Id" asp-route-subordinatesPage="@(Model.SubordinatesPage - 1)">Önceki</a>
                                </li>
                            }
                            @for (var pg = 1; pg <= totalPages; pg++)
                            {
                                if (pg == Model.SubordinatesPage)
                                {
                                    <li class="page-item active" aria-current="page"><span class="page-link">@pg</span></li>
                                }
                                else
                                {
                                    <li class="page-item"><a class="page-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@Model.Personnel.Id" asp-route-subordinatesPage="@pg">@pg</a></li>
                                }
                            }
                            @if (Model.SubordinatesPage < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@Model.Personnel.Id" asp-route-subordinatesPage="@(Model.SubordinatesPage + 1)">Sonraki</a>
                                </li>
                            }
                        </ul>
                    </nav>
                    <p class="small text-muted mt-1 mb-0">@Model.SubordinatesTotalCount personel, sayfa @Model.SubordinatesPage / @totalPages</p>
                }
            </div>
        </div>
        }
        <div class="am-card mb-3">
            <div class="am-card-header">Zimmetteki donanım</div>
            <div class="am-card-body">
                @if (TempData["ZimmetNoteSuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
                        @TempData["ZimmetNoteSuccess"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }
                @if (TempData["ZimmetNoteError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
                        @TempData["ZimmetNoteError"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }
                @if (Model.AssetAssignments.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var z in Model.AssetAssignments)
                        {
                            var assetName = Model.AssetNames.TryGetValue(z.AssetId, out var an) ? an : "—";
                            var assetType = Model.AssetTypes.TryGetValue(z.AssetId, out var at) ? StatusLabels.AssetTypeLabel(at) : "—";
                            var zNotes = Model.AssignmentNotes.GetValueOrDefault(z.Id, new List<AssetAssignmentNote>());
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@assetName <small class="text-muted">(@assetType)</small></span>
                                    <span class="small text-muted">@z.AssignedAt.ToString("dd.MM.yyyy")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(z.Notes))
                                {
                                    <div class="mt-1 small text-muted"><strong>Açıklama:</strong> @z.Notes</div>
                                }
                                <div class="mt-2">
                                    <div class="small fw-semibold mb-1">Notlar</div>
                                    @if (zNotes.Any())
                                    {
                                        <ul class="list-unstyled small mb-2">
                                            @foreach (var zn in zNotes)
                                            {
                                                <li class="mb-1"><span class="text-muted">@zn.CreatedAt.ToString("dd.MM.yyyy HH:mm") — @(zn.CreatedByUserName ?? "?"):</span> @zn.Content</li>
                                            }
                                        </ul>
                                    }
                                    <form method="post" asp-controller="Personnel" asp-action="AddZimmetNote" asp-route-id="@Model.Personnel.Id" asp-route-assignmentId="@z.Id" class="d-flex gap-2 align-items-end">
                                        @Html.AntiForgeryToken()
                                        <div class="flex-grow-1">
                                            <input type="text" name="Content" class="form-control form-control-sm" placeholder="Not ekle..." maxlength="2000" required />
                                        </div>
                                        <button type="submit" class="btn btn-am-primary btn-sm">Ekle</button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">Zimmette donanım yok.</p>
                    <a asp-controller="Personnel" asp-action="AssignAsset" asp-route-id="@Model.Personnel.Id" class="btn btn-am-outline btn-am-outline-solid btn-sm mt-2">Donanım ekle</a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="am-card mb-3">
            @{ var activeAccessCount = Model.AccessList.Count(a => a.IsActive); }
            <div class="am-card-header">Aktif Yetkiler / @activeAccessCount</div>
            <div class="am-card-body">
                @if (Model.AllSystems.Any())
                {
                    var systemsSorted = Model.AllSystems
                        .OrderByDescending(s => Model.AccessList.Any(a => a.ResourceSystemId == s.Id && a.IsActive))
                        .ThenBy(s => Model.SystemNames.GetValueOrDefault(s.Id, ""))
                        .ToList();
                    <div class="am-table-wrap am-access-list-scroll">
                        <table class="am-table mb-0">
                            <thead>
                                <tr>
                                    <th class="am-table-th-normal">Uygulama</th>
                                    <th class="am-table-th-normal">Sorumlu Kişi</th>
                                    <th class="am-table-th-normal">Sorumlu Departman</th>
                                    <th class="am-table-th-normal">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sys in systemsSorted)
                                {
                                    var access = Model.AccessList.FirstOrDefault(a => a.ResourceSystemId == sys.Id);
                                    var sysName = Model.SystemNames.GetValueOrDefault(sys.Id, sys.Name ?? sys.Code ?? sys.Id.ToString());
                                    var isActive = access?.IsActive == true;
                                    var isOffboardedWithOpen = Model.Personnel != null && Model.Personnel.EndDate.HasValue && isActive;
                                    var rowWarningClass = isOffboardedWithOpen ? "am-row-warning" : "";
                                    <tr class="@rowWarningClass">
                                        <td>@sysName @(access?.ExpiresAt.HasValue == true ? $" — Bitiş: {access.ExpiresAt!.Value:dd.MM.yyyy}" : "")</td>
                                        <td>
                                            @if (sys.OwnerId.HasValue && Model.SystemOwnerNames.TryGetValue(sys.Id, out var ownerName))
                                            {
                                                <a class="am-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@sys.OwnerId.Value">@ownerName</a>
                                            }
                                            else
                                            {
                                                @:—
                                            }
                                        </td>
                                        <td>
                                            @if (sys.ResponsibleDepartmentId.HasValue && Model.SystemResponsibleDepartmentNames.TryGetValue(sys.Id, out var deptName))
                                            {
                                                <a class="am-link" asp-controller="Departments" asp-action="Detail" asp-route-id="@sys.ResponsibleDepartmentId.Value">@deptName</a>
                                            }
                                            else
                                            {
                                                @:—
                                            }
                                        </td>
                                        <td>
                                            @if (isActive)
                                            {
                                                <form method="post" asp-controller="Personnel" asp-action="RevokeAccess" asp-route-id="@Model.Personnel.Id" asp-route-accessId="@access!.Id" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-link p-0 border-0 text-decoration-none am-access-toggle am-access-toggle--active" style="cursor:pointer;">Aktif</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-controller="Personnel" asp-action="GrantAccess" asp-route-id="@Model.Personnel.Id" asp-route-systemId="@sys.Id" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-link p-0 border-0 text-decoration-none am-access-toggle am-access-toggle--passive" style="cursor:pointer;">Pasif</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">Uygulama tanımı yok.</p>
                }
                <a asp-controller="AccessRequests" asp-action="Create" asp-route-personnelId="@Model.Personnel.Id" class="btn btn-am-outline btn-am-outline-solid btn-sm mt-2">Yetki talebi oluştur</a>
            </div>
        </div>
        <div class="am-card mb-3">
            <div class="am-card-header">Notlar</div>
            <div class="am-card-body">
                @if (TempData["NoteSuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
                        @TempData["NoteSuccess"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }
                @if (TempData["NoteError"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
                        @TempData["NoteError"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                }
                <form method="post" asp-controller="Personnel" asp-action="AddNote" asp-route-id="@Model.Personnel.Id" class="mb-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label for="Content" class="form-label">Yeni not</label>
                        <textarea name="Content" id="Content" class="form-control" rows="2" maxlength="2000" placeholder="Notunuzu yazın..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-am-primary btn-sm">Not ekle</button>
                </form>
                @if (Model.Notes.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var n in Model.Notes)
                        {
                            <li class="list-group-item px-0">
                                <div class="small text-muted mb-1">@n.CreatedAt.ToString("dd.MM.yyyy HH:mm") — @(n.CreatedByUserName ?? "?")</div>
                                <div>@n.Content</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0 small">Henüz not yok.</p>
                }
            </div>
        </div>
        @if (Model.Personnel.EndDate.HasValue == true && Model.AccessList.Any(a => a.IsActive))
        {
            <div class="am-card mb-3 border-warning">
                <div class="am-card-header text-warning">İşten çıkmış ama açık yetkisi olan</div>
                <div class="am-card-body">
                    <ul class="list-group list-group-flush">
                        @foreach (var a in Model.AccessList.Where(a => a.IsActive))
                        {
                            var sysName = Model.SystemNames.TryGetValue(a.ResourceSystemId, out var n) ? n : a.ResourceSystemId.ToString();
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@sysName</span>
                                <span class="d-flex align-items-center gap-2">
                                    <span class="am-badge success">Açık</span>
                                    <form method="post" asp-controller="Personnel" asp-action="RevokeAccess" asp-route-id="@Model.Personnel.Id" asp-route-accessId="@a.Id" class="d-inline" data-am-confirm="Bu yetki kapatılsın mı?">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-am-ghost btn-sm text-danger py-0">Yetkiyi kapat</button>
                                    </form>
                                </span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="personnelEditModal" tabindex="-1" aria-labelledby="personnelEditModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="personnelEditModalLabel">Kişisel bilgileri düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <form method="post" asp-controller="Personnel" asp-action="UpdatePersonnel" asp-route-id="@Model.Personnel.Id">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="editFirstName" class="form-label">Ad</label>
                            <input type="text" name="FirstName" id="editFirstName" class="form-control" value="@Model.Personnel.FirstName" required maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label for="editLastName" class="form-label">Soyad</label>
                            <input type="text" name="LastName" id="editLastName" class="form-control" value="@Model.Personnel.LastName" required maxlength="100" />
                        </div>
                        <div class="col-12">
                            <label for="editEmail" class="form-label">E-posta</label>
                            <input type="email" name="Email" id="editEmail" class="form-control" value="@Model.Personnel.Email" required maxlength="255" />
                        </div>
                        <div class="col-md-6">
                            <label for="editDepartmentId" class="form-label">Departman</label>
                            <select name="DepartmentId" id="editDepartmentId" class="form-select" required>
                                @foreach (var d in departmentsForEdit)
                                {
                                    if (Model.Personnel.DepartmentId == d.Id)
                                    {
                                        <option value="@d.Id" selected>@d.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@d.Id">@d.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="editPosition" class="form-label">Pozisyon</label>
                            <input type="text" name="Position" id="editPosition" class="form-control" value="@Model.Personnel.Position" maxlength="200" />
                        </div>
                        <div class="col-md-6">
                            <label for="editRoleId" class="form-label">Rol</label>
                            <select name="RoleId" id="editRoleId" class="form-select">
                                <option value="">— Seçiniz —</option>
                                @foreach (var r in rolesForEdit)
                                {
                                    if (Model.Personnel.RoleId == r.Id)
                                    {
                                        <option value="@r.Id" selected>@r.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@r.Id">@r.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="editManagerId" class="form-label">Yönetici</label>
                            <select name="ManagerId" id="editManagerId" class="form-select">
                                <option value="">— Yönetici yok —</option>
                                @foreach (var p in managersForEdit)
                                {
                                    if (Model.Personnel.ManagerId == p.Id)
                                    {
                                        <option value="@p.Id" selected>@p.FirstName @p.LastName</option>
                                    }
                                    else
                                    {
                                        <option value="@p.Id">@p.FirstName @p.LastName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="editStartDate" class="form-label">İşe giriş</label>
                            <input type="date" name="StartDate" id="editStartDate" class="form-control" value="@Model.Personnel.StartDate.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-6">
                            <label for="editEndDate" class="form-label">İşten çıkış</label>
                            <input type="date" name="EndDate" id="editEndDate" class="form-control" value="@(Model.Personnel.EndDate?.ToString("yyyy-MM-dd") ?? "")" />
                        </div>
                        <div class="col-md-6">
                            <label for="editStatus" class="form-label">Durum</label>
                            <select name="Status" id="editStatus" class="form-select">
                                @{
                                    var statusOptions = new[] { (0, "Aktif"), (1, "Pasif"), (2, "İşten ayrıldı") };
                                }
                                @foreach (var so in statusOptions)
                                {
                                    if ((int)Model.Personnel.Status == so.Item1)
                                    {
                                        <option value="@so.Item1" selected>@so.Item2</option>
                                    }
                                    else
                                    {
                                        <option value="@so.Item1">@so.Item2</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <div class="am-manager-toggle">
                                <input type="checkbox" name="IsManager" id="editIsManager" value="true" class="am-manager-toggle__input" @(isManager ? "checked" : "") />
                                <label for="editIsManager" class="am-manager-toggle__btn">Yönetici olarak işaretle</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-am-ghost" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-am-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<a asp-controller="Personnel" asp-action="Index" class="btn btn-am-ghost">Listeye dön</a>
}
