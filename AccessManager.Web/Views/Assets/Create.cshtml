@model AccessManager.UI.ViewModels.AssetEditInputModel
@using AccessManager.Domain.Enums
@{
    ViewData["Title"] = "Yeni Donanım";
}

<div class="am-card am-card--narrow">
    <div class="am-card-body">
        <form method="post" asp-controller="Assets" asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <div class="mb-3">
                <label asp-for="AssetType" class="form-label">Tür</label>
                <select asp-for="AssetType" class="form-select">
                    @foreach (AssetType t in Enum.GetValues(typeof(AssetType)))
                    {
                        <option value="@t">@StatusLabels.AssetTypeLabel(t)</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Ad <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Örn. Dizüstü-001" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SerialNumber" class="form-label">Seri no</label>
                <input asp-for="SerialNumber" class="form-control" placeholder="Örn. SN-12345" />
            </div>
            <div class="mb-3">
                <label asp-for="BrandModel" class="form-label">Marka / model</label>
                <input asp-for="BrandModel" class="form-control" placeholder="Örn. Dell Latitude 5520" />
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label">Durum</label>
                <select asp-for="Status" class="form-select">
                    @foreach (AssetStatus s in Enum.GetValues(typeof(AssetStatus)))
                    {
                        <option value="@s">@StatusLabels.AssetStatusLabel(s)</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="PurchaseDate" class="form-label">Satın alma tarihi</label>
                <input asp-for="PurchaseDate" class="form-control" type="date" />
            </div>
            <div class="mb-3">
                <label asp-for="PurchasePrice" class="form-label">Satın alma ücreti</label>
                <div class="row g-2">
                    <div class="col">
                        <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" min="0" placeholder="Örn. 15000,50" />
                    </div>
                    <div class="col-auto">
                        <select asp-for="PurchaseCurrency" class="form-select" style="min-width: 7rem;">
                            @foreach (var c in AccessManager.UI.Helpers.CurrencyHelper.GetCurrencies())
                            {
                                <option value="@c.Code">@c.Label</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="DepreciationYears" class="form-label">Amortisman süresi (yıl)</label>
                <select asp-for="DepreciationYears" class="form-select" style="max-width: 8rem;">
                    <option value="">—</option>
                    <option value="1">1 yıl</option>
                    <option value="2">2 yıl</option>
                    <option value="3">3 yıl</option>
                    <option value="4">4 yıl</option>
                    <option value="5">5 yıl</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="DepreciationEndDate" class="form-label">Amortisman bitiş tarihi</label>
                <input asp-for="DepreciationEndDate" class="form-control" type="date" />
                <span class="form-text">Boş bırakılırsa satın alma + amortisman süresi kullanılır.</span>
            </div>
            <div class="row g-2">
                <div class="col-md-6 mb-3">
                    <label asp-for="SpecRamGb" class="form-label">RAM (GB)</label>
                    <input asp-for="SpecRamGb" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SpecStorageGb" class="form-label">Depolama (GB)</label>
                    <input asp-for="SpecStorageGb" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SpecCpu" class="form-label">İşlemci</label>
                    <input asp-for="SpecCpu" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SpecScreenInches" class="form-label">Ekran (inç)</label>
                    <input asp-for="SpecScreenInches" class="form-control" type="number" step="0.1" min="0" />
                </div>
                <div class="col-md-6 mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="SpecIsPivot" class="form-check-input" />
                        <label asp-for="SpecIsPivot" class="form-check-label">Pivot (monitör)</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label">Not</label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-am-primary">Oluştur</button>
                <a asp-controller="Assets" asp-action="Index" class="btn btn-am-ghost">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
