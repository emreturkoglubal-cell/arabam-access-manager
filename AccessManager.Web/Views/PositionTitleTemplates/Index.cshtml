@using AccessManager.Domain.Entities
@{
    ViewData["Title"] = "Ünvan şablonları";
    var rows = ViewBag.Rows as IReadOnlyList<PositionTitleTemplate> ?? new List<PositionTitleTemplate>();
    var departments = ViewBag.Departments as IReadOnlyList<Department> ?? new List<Department>();
    var teams = ViewBag.Teams as IReadOnlyList<Team> ?? new List<Team>();
}

@if (TempData["PttSuccess"] != null)
{
    <div class="alert alert-success py-2">@TempData["PttSuccess"]</div>
}
@if (TempData["PttError"] != null)
{
    <div class="alert alert-danger py-2">@TempData["PttError"]</div>
}

<div class="am-card mb-4">
    <div class="am-card-body border-bottom bg-light">
        <strong>Bu sayfanın amacı:</strong> İşe girişte departman/ekip/seviye seçimine göre ünvan alanını otomatik ve tutarlı doldurmak.
        İstediğiniz metni ekleyebilir, mevcut şablonları düzenleyebilir veya silebilirsiniz.
    </div>
    <div class="am-card-header">Yeni şablon</div>
    <div class="am-card-body">
        <form method="post" asp-action="Create" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-3">
                <label class="form-label">Departman (boş = genel)</label>
                <select name="DepartmentId" class="form-select form-select-sm">
                    <option value="">—</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d.Id">@d.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Ekip (boş = genel)</label>
                <select name="TeamId" class="form-select form-select-sm">
                    <option value="">—</option>
                    @foreach (var t in teams)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Seviye</label>
                <input type="text" name="SeniorityLevel" class="form-control form-control-sm" maxlength="50" list="senioritySuggestions" placeholder="Örn: Jr, Mid, Senior, Principal" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Ünvan metni *</label>
                <input type="text" name="Title" class="form-control form-control-sm" required maxlength="200" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-am-primary btn-sm">Ekle</button>
            </div>
        </form>
    </div>
</div>

<div class="am-card">
    <div class="am-card-header">Kayıtlı şablonlar</div>
    <div class="am-card-body p-0">
        <div class="am-table-wrap">
            <table class="am-table mb-0">
                <thead>
                    <tr>
                        <th>Departman</th>
                        <th>Ekip</th>
                        <th>Seviye</th>
                        <th>Ünvan</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in rows)
                    {
                        var formId = "ptt-update-" + r.Id;
                        <tr>
                            <td>
                                    <select name="DepartmentId" form="@formId" class="form-select form-select-sm" style="min-width: 180px;">
                                        <option value="">—</option>
                                        @foreach (var d in departments)
                                        {
                                            if (r.DepartmentId == d.Id)
                                            {
                                                <option selected value="@d.Id">@d.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@d.Id">@d.Name</option>
                                            }
                                        }
                                    </select>
                            </td>
                            <td>
                                    <select name="TeamId" form="@formId" class="form-select form-select-sm" style="min-width: 180px;">
                                        <option value="">—</option>
                                        @foreach (var t in teams)
                                        {
                                            if (r.TeamId == t.Id)
                                            {
                                                <option selected value="@t.Id">@t.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@t.Id">@t.Name</option>
                                            }
                                        }
                                    </select>
                            </td>
                            <td>
                                    <input type="text" name="SeniorityLevel" form="@formId" value="@r.SeniorityLevel" class="form-control form-control-sm" maxlength="50" list="senioritySuggestions" style="min-width: 140px;" />
                            </td>
                            <td>
                                    <input type="text" name="Title" form="@formId" value="@r.Title" class="form-control form-control-sm" required maxlength="200" style="min-width: 260px;" />
                            </td>
                            <td class="text-nowrap">
                                <form id="@formId" method="post" asp-action="Update" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-am-primary">Kaydet</button>
                                </form>
                                <form method="post" asp-action="Delete" asp-route-id="@r.Id" class="d-inline ms-1" onsubmit="return confirm('Silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-am-outline-danger">Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!rows.Any())
        {
            <p class="text-muted p-3 mb-0">Henüz şablon yok.</p>
        }
    </div>
</div>

<p class="mt-3"><a asp-controller="Home" asp-action="Index" class="btn btn-am-ghost">Panele dön</a></p>

<datalist id="senioritySuggestions">
    <option value="Intern"></option>
    <option value="Junior"></option>
    <option value="Mid"></option>
    <option value="Senior"></option>
    <option value="Lead"></option>
    <option value="Principal"></option>
    <option value="Manager"></option>
    <option value="Director"></option>
</datalist>
