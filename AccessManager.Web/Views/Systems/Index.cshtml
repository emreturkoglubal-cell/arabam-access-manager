@using AccessManager.Domain.Constants
@using AccessManager.Domain.Enums
@using AccessManager.Domain.Entities
@{
    ViewData["Title"] = "Uygulamalar";
    var systems = ViewBag.Systems as IReadOnlyList<ResourceSystem> ?? new List<ResourceSystem>();
    var ownerNames = ViewBag.OwnerNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var responsibleDepartmentNames = ViewBag.ResponsibleDepartmentNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var accessCounts = ViewBag.AccessCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

@if (User.IsInRole(AppRoleNames.Admin))
{
    <div class="am-toolbar mb-4">
        <div class="am-toolbar-end">
            <a asp-controller="Systems" asp-action="Create" class="btn btn-am-primary">Yeni Sistem</a>
        </div>
    </div>
}

<div class="am-card">
    <div class="am-card-body p-0">
        <div class="am-table-wrap">
            <table class="am-table am-table-rows-clickable">
                <thead>
                    <tr>
                        <th>Kod</th>
                        <th>Ad</th>
                        <th>Tür</th>
                        <th>Kritik seviye</th>
                        <th>Sorumlu Departman</th>
                        <th>Sorumlu Kişi</th>
                        <th>Aktif erişim sayısı</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in systems)
                    {
                        var detailUrl = Url.Action("Detail", "Systems", new { id = s.Id }) ?? "#";
                        <tr class="am-table-row-clickable" data-href="@detailUrl" role="button" tabindex="0" onclick="window.location.href=this.dataset.href">
                            <td>@(s.Code ?? "-")</td>
                            <td>@s.Name</td>
                            <td>@s.SystemType</td>
                            <td><span class="badge @(s.CriticalLevel == CriticalLevel.High ? "am-critical-high" : s.CriticalLevel == CriticalLevel.Medium ? "am-critical-medium" : "am-critical-low")">@s.CriticalLevel</span></td>
                            <td>
                                @if (s.ResponsibleDepartmentId.HasValue)
                                {
                                    var deptName = responsibleDepartmentNames.TryGetValue(s.Id, out var dn) ? dn : "—";
                                    <a class="am-link" asp-controller="Departments" asp-action="Detail" asp-route-id="@s.ResponsibleDepartmentId.Value">@deptName</a>
                                }
                                else
                                {
                                    @:—
                                }
                            </td>
                            <td>
                                @if (s.OwnerId.HasValue)
                                {
                                    var ownerName = ownerNames.TryGetValue(s.Id, out var owner) ? owner : "—";
                                    <a class="am-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@s.OwnerId.Value">@ownerName</a>
                                }
                                else
                                {
                                    @:—
                                }
                            </td>
                            <td>@(accessCounts.TryGetValue(s.Id, out var cnt) ? cnt : 0)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!systems.Any())
        {
            <p class="text-muted mb-0 p-3">Henüz sistem tanımlanmamış.</p>
        }
    </div>
</div>
