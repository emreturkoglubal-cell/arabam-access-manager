@using AccessManager.Domain.Entities
@using AccessManager.Domain.Enums
@using AccessManager.Domain.Constants
@using AccessManager.UI.Helpers
@{
    var ci = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
    ViewData["Title"] = "Uygulama Detay";
    var system = ViewBag.System as ResourceSystem;
    var personnelList = ViewBag.PersonnelList as IReadOnlyList<Personnel> ?? new List<Personnel>();
    var personnelTotalCount = ViewBag.PersonnelTotalCount as int? ?? 0;
    var personnelPageNumber = ViewBag.PersonnelPageNumber as int? ?? 1;
    var personnelTotalPages = ViewBag.PersonnelTotalPages as int? ?? 1;
    var personnelPageSize = ViewBag.PersonnelPageSize as int? ?? 10;
    var roleNames = ViewBag.RoleNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var managerNames = ViewBag.ManagerNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var ownerNames = ViewBag.OwnerNames as List<(int Id, string Name)> ?? new List<(int Id, string Name)>();
    var responsibleDepartmentName = ViewBag.ResponsibleDepartmentName as string ?? "—";
}
@if (system == null)
{
    <p class="text-muted">Uygulama bulunamadı.</p>
}
else
{
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Systems" asp-action="Index">Uygulamalar</a></li>
        <li class="breadcrumb-item active">@system.Name</li>
    </ol>
</nav>

<div class="am-card mb-3">
    <div class="am-card-header d-flex justify-content-between align-items-center">
        <span>Uygulama Bilgileri</span>
        @if (User.IsInRole(AppRoleNames.Admin))
        {
            <a asp-controller="Systems" asp-action="Edit" asp-route-id="@system.Id" class="btn btn-sm btn-am-outline">Düzenle</a>
        }
    </div>
    <div class="am-card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Kod</dt>
            <dd class="col-sm-8">@(system.Code ?? "—")</dd>
            <dt class="col-sm-4">Ad</dt>
            <dd class="col-sm-8">@system.Name</dd>
            <dt class="col-sm-4">Tür</dt>
            <dd class="col-sm-8">@system.SystemType</dd>
            <dt class="col-sm-4">Kritik seviye</dt>
            <dd class="col-sm-8"><span class="badge @(system.CriticalLevel == CriticalLevel.High ? "am-critical-high" : system.CriticalLevel == CriticalLevel.Medium ? "am-critical-medium" : "am-critical-low")">@system.CriticalLevel</span></dd>
            <dt class="col-sm-4">Sorumlu Departman</dt>
            <dd class="col-sm-8">
                @if (system.ResponsibleDepartmentId.HasValue)
                {
                    <a class="am-link" asp-controller="Departments" asp-action="Detail" asp-route-id="@system.ResponsibleDepartmentId.Value">@responsibleDepartmentName</a>
                }
                else
                {
                    @:—
                }
            </dd>
            <dt class="col-sm-4">@(ownerNames.Count == 1 ? "Sorumlu Kişi" : "Sorumlu Kişiler")</dt>
            <dd class="col-sm-8">
                @if (ownerNames.Any())
                {
                    @for (var i = 0; i < ownerNames.Count; i++)
                    {
                        var owner = ownerNames[i];
                        if (i > 0) { <text>, </text> }
                        <a class="am-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@owner.Id">@owner.Name</a>
                    }
                }
                else
                {
                    @:—
                }
            </dd>
            <dt class="col-sm-4">Açıklama</dt>
            <dd class="col-sm-8">@(system.Description ?? "—")</dd>
            <dt class="col-sm-4">Birim maliyeti</dt>
            <dd class="col-sm-8">@(system.UnitCost.HasValue ? system.UnitCost.Value.ToString("N2", ci) + " " + CurrencyHelper.GetSymbol(system.UnitCostCurrency) : "—")</dd>
            <dt class="col-sm-4">Aktif yetkili personel sayısı</dt>
            <dd class="col-sm-8">@personnelTotalCount</dd>
            <dt class="col-sm-4">Toplam maliyet</dt>
            <dd class="col-sm-8">@{
                var totalCost = system.UnitCost.HasValue && personnelTotalCount > 0 ? system.UnitCost.Value * personnelTotalCount : (decimal?)null;
            }@(totalCost.HasValue ? totalCost.Value.ToString("N2", ci) + " " + CurrencyHelper.GetSymbol(system.UnitCostCurrency) : "—")</dd>
        </dl>
    </div>
</div>

@if (ViewBag.SystemDetailCostJson != null)
{
<div class="am-card am-card--chart mb-3">
    <div class="am-card-header am-card-header--sm">Maliyet trendi (son 6 ay, USD — snapshot)</div>
    <div class="am-card-body am-card-body--chart" style="min-height: 220px;">
        <canvas id="chartSystemDetailCost"></canvas>
    </div>
</div>
}

<div class="am-card mb-3">
    <div class="am-card-header">Bu uygulamada aktif yetkisi olan personeller</div>
    <div class="am-card-body p-0">
        <div class="am-table-wrap">
            <table class="am-table am-table-rows-clickable">
                <thead>
                    <tr>
                        <th class="am-table-col-avatar"></th>
                        <th class="am-table-th-normal">Ad Soyad</th>
                        <th class="am-table-th-normal">E-posta</th>
                        <th class="am-table-th-normal">Rol</th>
                        <th class="am-table-th-normal">Yönetici İsmi</th>
                        <th class="am-table-th-normal">Giriş</th>
                        <th class="am-table-th-normal">Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in personnelList)
                    {
                        var roleName = p.RoleId.HasValue && roleNames.TryGetValue(p.RoleId.Value, out var rn) ? rn : "—";
                        var managerName = p.ManagerId.HasValue && managerNames.TryGetValue(p.ManagerId.Value, out var mn) ? mn : "—";
                        var detailUrl = Url.Action("Detail", "Personnel", new { id = p.Id }) ?? "#";
                        <tr class="am-table-row-clickable" data-href="@detailUrl" role="button" tabindex="0">
                            <td class="am-table-cell-avatar">
                                @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="" class="am-avatar am-avatar-sm" />
                                }
                                else
                                {
                                    <span class="am-avatar am-avatar-sm am-avatar-default" aria-hidden="true"><i class="bi bi-person-circle"></i></span>
                                }
                            </td>
                            <td>@p.FirstName @p.LastName</td>
                            <td>@p.Email</td>
                            <td>@roleName</td>
                            <td>@managerName</td>
                            <td>@p.StartDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                <span class="am-badge @(p.Status == PersonnelStatus.Active ? "success" : p.Status == PersonnelStatus.Offboarded ? "secondary" : "warning")">@StatusLabels.PersonnelStatus(p.Status)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!personnelList.Any())
        {
            <p class="text-muted mb-0 p-3">Bu uygulamada aktif yetkisi olan personel yok.</p>
        }
        else if (personnelTotalPages > 1)
        {
            <div class="p-3">
                @await Html.PartialAsync("_Pagination", new AccessManager.UI.ViewModels.PaginationViewModel
                {
                    Controller = "Systems",
                    Action = "Detail",
                    PageNumber = personnelPageNumber,
                    TotalPages = personnelTotalPages,
                    TotalCount = personnelTotalCount,
                    PageSize = personnelPageSize,
                    RouteValues = new Microsoft.AspNetCore.Routing.RouteValueDictionary { ["id"] = system.Id }
                })
            </div>
        }
    </div>
</div>

<a asp-controller="Systems" asp-action="Index" class="btn btn-am-ghost">Listeye dön</a>
}

@section Scripts {
@if (ViewBag.SystemDetailCostJson != null)
{
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
(function () {
    var pts = @Html.Raw(ViewBag.SystemDetailCostJson as string ?? "[]");
    if (!pts || !pts.length) return;
    var el = document.getElementById('chartSystemDetailCost');
    if (!el) return;
    var labels = pts.map(function (x) { return x.label; });
    var data = pts.map(function (x) { return Number(x.total); });
    var themeRed = '#e40030';
    var bg = data.map(function (v, i) {
        if (i === 0) return '#e5e7eb';
        var d = v - data[i - 1];
        return d > 0 ? '#fecaca' : d < 0 ? '#bbf7d0' : '#e5e7eb';
    });
    new Chart(el, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Toplam USD',
                data: data,
                backgroundColor: bg,
                borderColor: themeRed,
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        afterLabel: function (ctx) {
                            var i = ctx.dataIndex;
                            if (i > 0) {
                                var d = data[i] - data[i - 1];
                                return 'Önceki aya göre: ' + (d > 0 ? '+' : '') + d.toFixed(2) + ' USD';
                            }
                            return '';
                        }
                    }
                }
            },
            scales: {
                y: { beginAtZero: true, ticks: { font: { size: 10 } } },
                x: { ticks: { font: { size: 10 } } }
            }
        }
    });
})();
</script>
}
}
