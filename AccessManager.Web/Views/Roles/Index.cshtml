@using AccessManager.Domain.Constants
@using AccessManager.Domain.Entities
@{
    ViewData["Title"] = "Roller ve Yetkiler";
    var roles = ViewBag.Roles as IReadOnlyList<Role> ?? new List<Role>();
    var countByRole = ViewBag.PersonnelCountByRole as Dictionary<int, int> ?? new Dictionary<int, int>();
}

@if (User.IsInRole(AppRoleNames.Admin))
{
    <div class="am-toolbar mb-3">
        <div class="am-toolbar-end">
            <a asp-controller="Roles" asp-action="Create" class="btn btn-am-primary">Yeni Rol</a>
        </div>
    </div>
}

<div class="am-card">
    <div class="am-card-body p-0">
        <div class="am-table-wrap am-table-rows-clickable">
            <table class="am-table">
                <thead>
                    <tr>
                        <th class="am-table-th-normal">Kod</th>
                        <th class="am-table-th-normal">Rol adı</th>
                        <th class="am-table-th-normal">Açıklama</th>
                        <th class="am-table-th-normal">Personel sayısı</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in roles)
                    {
                        var detailUrl = Url.Action("Detail", "Roles", new { id = r.Id }) ?? "#";
                        <tr class="am-table-row-clickable" data-href="@detailUrl" role="button" tabindex="0">
                            <td>@(r.Code ?? "—")</td>
                            <td><strong>@r.Name</strong></td>
                            <td>@(string.IsNullOrEmpty(r.Description) ? "—" : (r.Description!.Length > 80 ? r.Description.Substring(0, 80) + "…" : r.Description))</td>
                            <td>@(countByRole.TryGetValue(r.Id, out var c) ? c : 0)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!roles.Any())
{
    <p class="text-muted mt-3">Henüz rol tanımlanmamış.</p>
}
