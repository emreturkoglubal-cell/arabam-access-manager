@model AccessManager.UI.Controllers.OffboardingInputModel
@using AccessManager.Domain.Entities
@using AccessManager.Application.Dtos
@{
    ViewData["Title"] = "İşten Çıkış";
    var activePersonnel = ViewBag.ActivePersonnel as IReadOnlyList<Personnel> ?? new List<Personnel>();
    var recentOffboarded = ViewBag.RecentOffboarded as IReadOnlyList<OffboardedReportRow> ?? new List<OffboardedReportRow>();
    var departments = ViewBag.Departments as IReadOnlyList<Department> ?? new List<Department>();
    var filterFrom = ViewBag.FilterFrom as DateTime? ?? DateTime.Today.AddMonths(-1);
    var filterTo = ViewBag.FilterTo as DateTime? ?? DateTime.Today;
    var filterDeptId = ViewBag.FilterDepartmentId as int?;
}

<p class="text-muted">Personel için çıkış tarihi girerek tüm yetkileri kapatın.</p>

<div class="am-card am-card--narrow">
    <div class="am-card-body">
        <form method="post" asp-controller="Offboarding" asp-action="Index" class="row g-3">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="col-12">
                <label asp-for="SelectedPersonnelId" class="form-label">Personel *</label>
                <select asp-for="SelectedPersonnelId" class="form-select" required>
                    <option value="">Seçiniz</option>
                    @foreach (var p in activePersonnel)
                    {
                        <option value="@p.Id">@p.FirstName @p.LastName (#@p.Id)</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="EndDate" class="form-label">Çıkış tarihi</label>
                <input asp-for="EndDate" type="text" class="form-control am-fp-date" asp-format="{0:yyyy-MM-dd}" placeholder="gg.aa.yyyy" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-am-primary btn-am-danger">İşten çıkış işlemini uygula</button>
                <a asp-controller="Personnel" asp-action="Index" class="btn btn-am-ghost">İptal</a>
            </div>
        </form>
    </div>
</div>

<div class="am-card mt-4">
    <div class="am-card-header">İşten çıkanlar listesi (filtre)</div>
    <div class="am-card-body">
        <form method="get" asp-controller="Offboarding" asp-action="Index" class="row g-2 align-items-end flex-wrap">
            <div class="col-auto">
                <label class="form-label small mb-0">Başlangıç</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@filterFrom.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <label class="form-label small mb-0">Bitiş</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@filterTo.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <label class="form-label small mb-0">Departman</label>
                <select name="departmentId" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d.Id" selected="@(filterDeptId == d.Id)">@d.Name</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-am-outline btn-sm">Uygula</button>
            </div>
        </form>
    </div>
</div>

@if (recentOffboarded.Any())
{
<div class="am-card mt-4">
    <div class="am-card-header">İşten çıkanlar (@recentOffboarded.Count kayıt)</div>
    <div class="am-card-body p-0">
        <div class="am-table-wrap">
            <table class="am-table mb-0">
                <thead>
                    <tr>
                        <th class="am-table-th-normal">Ad Soyad</th>
                        <th class="am-table-th-normal">İşe giriş</th>
                        <th class="am-table-th-normal">İşten çıkış</th>
                        <th class="am-table-th-normal">E-posta</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in recentOffboarded)
                    {
                        var rowClass = r.HasOpenAccess ? "table-danger" : "table-success";
                        <tr class="@rowClass">
                            <td><a class="am-link" asp-controller="Personnel" asp-action="Detail" asp-route-id="@r.PersonnelId">@(r.FullName ?? "—")</a></td>
                            <td>@(r.StartDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                            <td>@(r.EndDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                            <td>@(r.Email ?? "—")</td>
                            <td>
                                <a asp-controller="Offboarding" asp-action="ExitSummaryPdf" asp-route-id="@r.PersonnelId" class="btn btn-am-outline btn-sm" target="_blank">Özet PDF</a>
                                <a asp-controller="Personnel" asp-action="Detail" asp-route-id="@r.PersonnelId" class="btn btn-am-outline btn-sm" target="_blank">Detay</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
}
