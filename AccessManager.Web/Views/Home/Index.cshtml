@model AccessManager.Application.Dtos.DashboardStats
@using AccessManager.Domain.Entities
@{
    ViewData["Title"] = "Kontrol Paneli";
    var departments = ViewBag.Departments as IReadOnlyList<Department> ?? new List<Department>();
    var filterDepartmentId = ViewBag.DepartmentId as int?;
    var periodMonths = ViewBag.PeriodMonths as int? ?? 1;
}

<div class="am-toolbar mb-3">
    <form method="get" asp-controller="Home" asp-action="Index" class="d-flex flex-wrap gap-2 align-items-center">
        <label class="form-label mb-0">Departman</label>
        <select name="departmentId" class="form-select form-select-sm am-toolbar-select" style="max-width: 220px;">
            <option value="">Tümü</option>
            @foreach (var d in departments)
            {
                <option value="@d.Id" selected="@(filterDepartmentId == d.Id)">@d.Name</option>
            }
        </select>
        <label class="form-label mb-0">Dönem</label>
        <select name="periodMonths" class="form-select form-select-sm am-toolbar-select" style="max-width: 160px;">
            <option value="1" selected="@(periodMonths == 1)">Son 1 ay</option>
            <option value="2" selected="@(periodMonths == 2)">Son 2 ay</option>
            <option value="3" selected="@(periodMonths == 3)">Son 3 ay</option>
            <option value="6" selected="@(periodMonths == 6)">Son 6 ay</option>
            <option value="12" selected="@(periodMonths == 12)">Son 1 yıl</option>
            <option value="24" selected="@(periodMonths == 24)">Son 2 yıl</option>
        </select>
        <button type="submit" class="btn btn-am-outline btn-am-outline-solid btn-sm">Uygula</button>
    </form>
</div>

<div class="am-stat-cards mb-4">
    <a href="@Url.Action("Index", "Personnel", new { departmentId = filterDepartmentId })" class="am-stat-card am-stat-card-clickable d-block text-decoration-none text-body">
        <div class="label">Aktif Personel</div>
        <div class="value accent">@Model.ActivePersonnelCount</div>
        <div class="action"><span class="btn-am-ghost">Listele →</span></div>
    </a>
    <a href="@Url.Action("Index", "Reports")" class="am-stat-card am-stat-card-clickable d-block text-decoration-none text-body">
        <div class="label">@(periodMonths == 12 ? "Son 1 yıl" : periodMonths == 24 ? "Son 2 yıl" : $"Son {periodMonths} ay") İşten Ayrılan</div>
        <div class="value">@Model.OffboardedLastMonthCount</div>
        <div class="action"><span class="btn-am-ghost">Raporlar →</span></div>
    </a>
    <a href="@Url.Action("Index", "AccessRequests")" class="am-stat-card am-stat-card-clickable d-block text-decoration-none text-body">
        <div class="label">Bekleyen Talepler</div>
        <div class="value warning">@Model.PendingRequestsCount</div>
        <div class="action"><span class="btn-am-ghost">İncele →</span></div>
    </a>
    <a href="@Url.Action("Index", "Reports")" class="am-stat-card am-stat-card-clickable d-block text-decoration-none text-body">
        <div class="label">Süresi Dolacak Yetkiler (30 gün)</div>
        <div class="value info">@Model.ExpiringAccessCount</div>
        <div class="action"><span class="btn-am-ghost">Raporlar →</span></div>
    </a>
    <a href="@Url.Action("Index", "Reports")" class="am-stat-card am-stat-card-clickable d-block text-decoration-none text-body">
        <div class="label">Rol Dışı Yetkiler</div>
        <div class="value">@Model.ExceptionAccessCount</div>
        <div class="action"><span class="btn-am-ghost">Raporlar →</span></div>
    </a>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <div class="am-card am-card--chart h-100">
            <div class="am-card-header am-card-header--sm">Personel trendi (12 ay)</div>
            <div class="am-card-body am-card-body--chart">
                <canvas id="chartPersonnelTrend"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="am-card am-card--chart h-100">
            <div class="am-card-header am-card-header--sm">İşten ayrılan personel (12 ay)</div>
            <div class="am-card-body am-card-body--chart">
                <canvas id="chartOffboardedByMonth"></canvas>
            </div>
        </div>
    </div>
</div>
<div class="row g-2 mb-3">
    <div class="col-md-6">
        <div class="am-card am-card--chart h-100">
            <div class="am-card-header am-card-header--sm">Departmanlara göre</div>
            <div class="am-card-body am-card-body--chart">
                <canvas id="chartByDepartment"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="am-card am-card--chart h-100">
            <div class="am-card-header am-card-header--sm">Uygulamalara göre erişim (top 10)</div>
            <div class="am-card-body am-card-body--chart">
                <canvas id="chartAccessBySystem"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
(function () {
    var chartData = @Html.Raw(ViewBag.ChartDataJson ?? "null");
    if (!chartData) return;

    var themeRed = '#e40030';
    var themeRedDark = '#ab0025';
    var themeRedLight = '#fef2f2';

    if (chartData.personnelTrend && chartData.personnelTrend.length) {
        new Chart(document.getElementById('chartPersonnelTrend'), {
            type: 'line',
            data: {
                labels: chartData.personnelTrend.map(function (x) { return x.label; }),
                datasets: [{
                    label: 'Aktif personel',
                    data: chartData.personnelTrend.map(function (x) { return x.count; }),
                    borderColor: themeRed,
                    backgroundColor: themeRedLight,
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1, font: { size: 10 } } },
                    x: { ticks: { font: { size: 10 } } }
                }
            }
        });
    }

    if (chartData.offboardedByMonth && chartData.offboardedByMonth.length) {
        new Chart(document.getElementById('chartOffboardedByMonth'), {
            type: 'bar',
            data: {
                labels: chartData.offboardedByMonth.map(function (x) { return x.label; }),
                datasets: [{
                    label: 'İşten ayrılan',
                    data: chartData.offboardedByMonth.map(function (x) { return x.count; }),
                    backgroundColor: themeRedDark,
                    borderColor: themeRed,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1, font: { size: 10 } } },
                    x: { ticks: { font: { size: 10 } } }
                }
            }
        });
    }

    if (chartData.personnelByDepartment && chartData.personnelByDepartment.length) {
        var dept = chartData.personnelByDepartment.slice().sort(function (a, b) { return b.count - a.count; });
        var maxCount = Math.max.apply(null, dept.map(function (x) { return x.count; })) || 1;
        function hexToRgb(h) {
            var r = parseInt(h.slice(1, 3), 16), g = parseInt(h.slice(3, 5), 16), b = parseInt(h.slice(5, 7), 16);
            return { r: r, g: g, b: b };
        }
        function rgbToHex(r, g, b) {
            return '#' + [r, g, b].map(function (c) { return ('0' + Math.round(c).toString(16)).slice(-2); }).join('');
        }
        function lerpColor(lightHex, darkHex, t) {
            var L = hexToRgb(lightHex), D = hexToRgb(darkHex);
            return rgbToHex(L.r + (D.r - L.r) * t, L.g + (D.g - L.g) * t, L.b + (D.b - L.b) * t);
        }
        var deptColors = dept.map(function (x) {
            var t = maxCount > 0 ? x.count / maxCount : 0;
            return lerpColor(themeRedLight, themeRedDark, t);
        });
        new Chart(document.getElementById('chartByDepartment'), {
            type: 'doughnut',
            data: {
                labels: dept.map(function (x) { return x.label; }),
                datasets: [{
                    data: dept.map(function (x) { return x.count; }),
                    backgroundColor: deptColors
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'right', labels: { font: { size: 10 }, boxWidth: 10 } } }
            }
        });
    }

    if (chartData.accessBySystem && chartData.accessBySystem.length) {
        new Chart(document.getElementById('chartAccessBySystem'), {
            type: 'bar',
            data: {
                labels: chartData.accessBySystem.map(function (x) { return x.label; }),
                datasets: [{
                    label: 'Aktif erişim',
                    data: chartData.accessBySystem.map(function (x) { return x.count; }),
                    backgroundColor: themeRed,
                    borderColor: themeRedDark,
                    borderWidth: 1
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { beginAtZero: true, ticks: { stepSize: 1, font: { size: 10 } } },
                    y: { ticks: { font: { size: 10 } } }
                }
            }
        });
    }
})();
</script>
}
